# ========== AI 提供方（可选，默认 openai）==========
# openai  — OpenAI 或任意 OpenAI 兼容网关（默认）
# deepseek — DeepSeek 官方 API
# WORKLOG_PROVIDER=openai

# ========== OpenAI 兼容 API（默认提供方）==========
# 必填其一
WORKLOG_API_KEY=sk-your-openai-key
# 或
# OPENAI_API_KEY=sk-...

# 可选：自建/企业网关（不填则使用官方地址）
# WORKLOG_API_BASE=https://api.openai.com/v1
# WORKLOG_MODEL=gpt-4o-mini

# ========== DeepSeek（当 WORKLOG_PROVIDER=deepseek 时）==========
# 推荐使用独立变量（也可共用 WORKLOG_API_KEY）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# 不设置 WORKLOG_API_BASE 时自动使用 https://api.deepseek.com/v1
# 不设置 WORKLOG_MODEL 时自动使用 deepseek-chat
